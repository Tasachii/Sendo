# Copy to .env and fill in. Generate a secret with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-random-32-byte-base64-string"

# Enable only behind a proxy that strips/rebuilds X-Forwarded-For/X-Real-IP.
# Otherwise registration shares one conservative anonymous-source budget per process.
TRUST_PROXY_HEADERS="false"
